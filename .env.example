# ─────────────────────────────────────────────────────────────────────────────
# AI E-Commerce Operations Brain — Environment Variables
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is gitignored.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=ecomops
POSTGRES_PASSWORD=change-me-in-dev
# These are overridden in docker-compose.yml to use service hostnames.
# Use localhost URLs when running the app outside Docker.
DATABASE_URL=postgresql+asyncpg://ecomops:change-me-in-dev@localhost:5432/ecom_brain
DATABASE_URL_SYNC=postgresql://ecomops:change-me-in-dev@localhost:5432/ecom_brain

# ── Qdrant ────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=incidents

# ── Azure OpenAI ──────────────────────────────────────────────────────────────
# Required for all LLM nodes. Get from Azure Portal → Cognitive Services.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_API_VERSION=2024-12-01-preview
# Deployment names — must match what you created in Azure OpenAI Studio
AZURE_OPENAI_DEPLOYMENT_GPT4O=gpt-4o
AZURE_OPENAI_DEPLOYMENT_GPT4O_MINI=gpt-4o-mini
AZURE_OPENAI_DEPLOYMENT_EMBEDDING=text-embedding-3-small

# ── LangSmith (LangGraph native tracing) ─────────────────────────────────────
# Create a project at https://smith.langchain.com, then copy keys.
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=ai-ops-brain
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# ── Langfuse (LLM observability — Cloud, free tier) ───────────────────────────
# Sign up at https://cloud.langfuse.com → Settings → API Keys
# Decision: using Langfuse Cloud instead of self-hosted (see DECISIONS.md).
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ── OTel (HTTP + DB spans → any OTLP-compatible backend) ─────────────────────
# Langfuse Cloud accepts OTLP at https://cloud.langfuse.com/api/public/otel
# Or point to a local collector.
OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel
OTEL_SERVICE_NAME=ai-ops-backend

# ── Security ──────────────────────────────────────────────────────────────────
# Change JWT_SECRET_KEY to a long random string before any non-local deployment.
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=DEBUG

# ── LangGraph graph settings ──────────────────────────────────────────────────
# IMPORTANT: These are INDEPENDENT values — never derive RECURSION_LIMIT
# from MAX_RETRIES. See BLUEPRINT §5 (S-NEW-6) and DECISIONS.md.
MAX_RETRIES=3
RECURSION_LIMIT=50

# ── Memory retrieval ──────────────────────────────────────────────────────────
MEMORY_SIM_THRESHOLD=0.72
SIM_WEIGHT=0.6
RECENCY_WEIGHT=0.4

# ── HITL ──────────────────────────────────────────────────────────────────────
HITL_TIMEOUT_HOURS=24
